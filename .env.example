# =============================================================
# GeNe Mobile Environment Example
# =============================================================
# Copy this file to `.env` and replace placeholder values.
#
# IMPORTANT:
# 1) Any variable starting with EXPO_PUBLIC_ is bundled into the app.
#    Do NOT put highly sensitive secrets here.
# 2) Restart Expo after editing `.env`.
# =============================================================

# Toggle backend mode.
# - true  -> uses EXPO_PUBLIC_FASTAPI_BASE_URL
# - false -> uses EXPO_PUBLIC_LEGACY_API_BASE_URL
EXPO_PUBLIC_USE_FASTAPI=true

# Primary backend base URL (FastAPI).
# Must include the API prefix used by your backend routes.
# Example: https://your-domain.com/api/v1
EXPO_PUBLIC_FASTAPI_BASE_URL=https://your-fastapi-url/api/v1

# Fallback/legacy backend base URL (typically local dev server).
# Example local LAN host: http://192.168.1.83:5000/api
EXPO_PUBLIC_LEGACY_API_BASE_URL=http://192.168.1.83:5000/api


# --------------------------
# Freesound API configuration
# --------------------------

# Freesound text search endpoint used to find tracks.
EXPO_PUBLIC_FREESOUND_API_BASE_URL=https://freesound.org/apiv2/search/text/

# Freesound API token.
# Obtain from: https://freesound.org/apiv2/apply/
# Note: This is client-visible because of EXPO_PUBLIC_ prefix.
EXPO_PUBLIC_FREESOUND_API_KEY=your_freesound_api_key


# ---------------------------------
# WebSocket endpoints for sensor data
# ---------------------------------

# iOS WebSocket base URL.
# Use your machine's LAN IP when testing on a physical iPhone/iPad.
# Example: ws://192.168.1.83:8765
EXPO_PUBLIC_WS_BASE_URL_IOS=ws://192.168.1.83:8765

# Android WebSocket base URL.
# - Android Emulator: use ws://10.0.2.2:8765 (special alias to host machine)
# - Physical Android device: use your machine LAN IP (e.g. ws://192.168.1.83:8765)
EXPO_PUBLIC_WS_BASE_URL_ANDROID=ws://10.0.2.2:8765

# Fallback WebSocket URL for other platforms.
EXPO_PUBLIC_WS_BASE_URL_DEFAULT=ws://192.168.1.83:8765


# -----------------
# IP address notes
# -----------------
# 192.168.x.x : Your computer's local network (LAN) IP.
#               Use this when phone and computer are on same Wi-Fi.
# 10.0.2.2    : Android emulator alias that points to your host computer.
# localhost   : Refers to the current device itself (usually NOT what you want
#               from mobile app if backend runs on your computer).
